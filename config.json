{
  "sample_rate": 16000,
  "hotkey": {
    "windows": "ctrl_r",
    "darwin": "alt_r"
  },
  "whisper": {
    "windows": {
      "backend": "faster-whisper",
      "model_size": "small",
      "device": "cuda",
      "compute_type": "float16"
    },
    "darwin": {
      "backend": "mlx-whisper",
      "model_size": "small"
    }
  },
  "cleanup": {
    "backend": "local",
    "ollama_model": "llama3.2:3b",
    "ollama_url": "http://localhost:11434/api/generate"
  },
  "autostart": false
}
